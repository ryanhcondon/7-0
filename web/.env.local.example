# Copy to .env.local (gitignored) and fill in. Also set these in Vercel:
# Project → Settings → Environment Variables. Never commit real values.

# --- Supabase (draft cache) ------------------------------------------------
# From Supabase dashboard → Project Settings → API.
# SUPABASE_URL is public; SERVICE_ROLE is SECRET and server-only (never ship to
# the browser). If either is unset the proxy still works, just uncached.
SUPABASE_URL=https://hvvdegbwdiumjtoapjxa.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- 17lands proxy ---------------------------------------------------------
# Master on/off switch for live 17lands calls. Must be exactly "true" to enable.
# Leave unset/false until 17lands grants permission — proxy then serves cache only.
LIVE_17LANDS_ENABLED=false

# Optional: stable public URL put in the User-Agent sent to 17lands. On Vercel,
# VERCEL_URL is auto-set per deploy and used as a fallback, so this is only
# needed to pin a custom production domain.
# APP_PUBLIC_URL=https://your-domain.com
